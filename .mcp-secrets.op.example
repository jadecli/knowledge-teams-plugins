# ============================================================================
# .mcp-secrets.op — 1Password References for MCP Server Credentials
# ============================================================================
# This file maps MCP server env vars to 1Password secret references.
# Resolved at session start by resolve-mcp-secrets.sh via `op inject`.
#
# Your mcp.json should use ${ENV_VAR} placeholders, not raw tokens.
# This file resolves those env vars from 1Password vaults.
#
# Password Rotation:
#   Rotate secrets in 1Password vault -> next session auto-picks up new values.
#   No code changes, no redeployment, no .env editing.
#
# Setup:
#   1. cp .mcp-secrets.op.example .mcp-secrets.op
#   2. Create matching items in your 1Password vault
#   3. Update op:// paths below to match your vault structure
#
# Sources:
#   - https://1password.com/blog/securing-mcp-servers-with-1password
#   - https://developer.1password.com/docs/cli/secret-references
# ============================================================================

# GitHub MCP Server
export GITHUB_TOKEN=op://Development/github-mcp/token

# Postgres MCP Server (Supabase, Neon, etc.)
export POSTGRES_CONNECTION_STRING=op://Development/postgres-mcp/connection-string

# Slack MCP Server
export SLACK_BOT_TOKEN=op://Development/slack-mcp/bot-token
export SLACK_TEAM_ID=op://Development/slack-mcp/team-id

# Linear MCP Server
export LINEAR_API_KEY=op://Development/linear-mcp/api-key

# Sentry MCP Server
export SENTRY_AUTH_TOKEN=op://Development/sentry-mcp/auth-token
export SENTRY_ORG=op://Development/sentry-mcp/org-slug

# Memory / Context MCP Server
export MEMORY_STORE_PATH=op://Development/memory-mcp/store-path

# Custom Internal MCP Servers
export INTERNAL_API_KEY=op://Development/internal-mcp/api-key
export INTERNAL_API_URL=op://Development/internal-mcp/base-url
