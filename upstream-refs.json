  "sdks": {
    "anthropic": {
      "npmPackage": "@anthropic-ai/sdk",
      "version": "^0.78.0"
    },
    "claude-agent-sdk": {
      "npmPackage": "@anthropic-ai/claude-agent-sdk",
      "version": null
    },
    "tweakcc": {
      "npmPackage": "tweakcc",
      "version": "^4.0.11"
    }
  },
  "cloudProviders": {
    "anthropic-direct": {
      "envKey": "ANTHROPIC_API_KEY",
      "authMode": "api-key"
    },
    "anthropic-pro-max": {
      "envKey": null,
      "authMode": "pro-max"
    },
    "aws-bedrock": {
      "envKey": "AWS_ACCESS_KEY_ID",
      "authMode": "bedrock",
      "requiredEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_REGION"],
      "optionalEnv": ["AWS_SESSION_TOKEN", "ANTHROPIC_BEDROCK_MODEL_ID"]
    },
    "gcp-vertex": {
      "envKey": "GOOGLE_APPLICATION_CREDENTIALS",
      "authMode": "vertex",
      "requiredEnv": ["GOOGLE_APPLICATION_CREDENTIALS", "CLOUD_ML_REGION"],
      "optionalEnv": ["ANTHROPIC_VERTEX_PROJECT_ID"]
    }
  }
