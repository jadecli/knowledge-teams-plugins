# ============================================================================
# .env.op — 1Password Secret References (Safe to Commit)
# ============================================================================
# Uses op:// URI format. Secrets are resolved at runtime by `op inject`
# or `op run`, never stored in plaintext.
#
# Format: op://<vault>/<item>/<field>
#
# Setup:
#   1. Install 1Password CLI: https://developer.1password.com/docs/cli
#   2. Sign in: `op signin` (desktop) or set OP_SERVICE_ACCOUNT_TOKEN (CI)
#   3. Create vault items matching the references below
#   4. Copy this file to .env.op and update vault/item/field paths
#
# Usage with Claude Code SessionStart hook:
#   The session-start.sh hook auto-detects .env.op and resolves via `op inject`
#
# Usage standalone:
#   op inject --in-file .env.op --out-file .env
#   op run --env-file .env.op -- your-command
#
# Sources:
#   - https://1password.com/blog/securing-mcp-servers-with-1password
#   - https://developer.1password.com/docs/cli/secret-references
# ============================================================================

# Anthropic API (for api-key and enterprise auth modes)
export ANTHROPIC_API_KEY=op://Development/anthropic-api/credential
export JADE_ENTERPRISE_API_KEY=op://Development/jade-enterprise/api-key

# MCP Server Secrets (resolved by op, never in mcp.json)
export GITHUB_TOKEN=op://Development/github-pat/token
export LINEAR_API_KEY=op://Development/linear/api-key
export SLACK_BOT_TOKEN=op://Development/slack-bot/oauth-token
export SENTRY_AUTH_TOKEN=op://Development/sentry/auth-token

# Database (for data VP agent)
export DATABASE_URL=op://Development/postgres/connection-string

# 1Password Service Account (for CI/CD and Claude Code web)
# Set this as a repository secret, not in this file:
# OP_SERVICE_ACCOUNT_TOKEN=<set-in-ci-secrets>
# OP_VAULT=Development
# OP_ITEM=claude-code-env
