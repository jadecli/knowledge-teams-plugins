{
  "name": "@jadecli/knowledge-teams-plugins",
  "version": "0.1.0",
  "description": "S-team compose layer + WebMCP tools — extends Anthropic knowledge-work-plugins",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:commits": "commitlint --from HEAD~1 --to HEAD --verbose",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "manifests:check": "node -e \"const m=require('./manifests/stainless-features.json');console.log(m.summary.implemented+'/'+m.summary.total+' features ('+m.summary.percentComplete+'%)');\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "tweakcc": "^4.0.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "^25.4.0",
    "conventional-changelog-cli": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": "./dist/src/jade/kw/index.js",
    "./kw": "./dist/src/jade/kw/index.js",
    "./admin": "./dist/src/jade/admin/index.js",
    "./deploy": "./dist/src/jade/deploy/index.js",
    "./compose": "./dist/compose/loader.js",
    "./enterprise": "./dist/src/jade/enterprise/index.js"
  },
  "license": "MIT"
}
