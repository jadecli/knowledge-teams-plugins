DATABASE_URL=postgresql://user:pass@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon API — required for branch-per-PR CI workflow
NEON_API_KEY=neon_api_xxxxx
NEON_PROJECT_ID=project-xxxxx

# Claude Organizations API — used for team usage metrics (live integration test)
ANTHROPIC_ORG_API_KEY=sk-ant-xxxxx
ANTHROPIC_ORG_ID=org-xxxxx
